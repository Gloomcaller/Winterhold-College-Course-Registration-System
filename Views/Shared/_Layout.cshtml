<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - College of Winterhold</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="icon" href="~/pngs/favicon.png" type="image/x-icon" />
</head>
<body>
    <header class="site-header">
        <div class="header-container">
            <div class="logo">
                <img src="~/pngs/CollegeofWinterholdLogo.png" alt="Winterhold College Logo" />
                <h1>College of Winterhold</h1>
                <p class="tagline">Where magic meets mastery</p>
            </div>
            <nav class="main-nav">
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/Course">Courses</a></li>
                    <li><a href="/Student/Enroll">Enroll</a></li>
                    <li><a href="/Home/About">About</a></li>
                    <li><a href="/Home/Contact">Contact</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-container">
            <p>© 4E 202 – College of Winterhold. All rights reserved.</p>
            <p>Arcanaeum Library • Hall of Elements • Winterhold, Skyrim</p>
            <p class="disclaimer">Use of magic without supervision is prohibited.</p>
        </div>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>