@{
    ViewData["Title"] = "Winterhold College";
}

<h1>Welcome to the College of Winterhold</h1>
<p>Skyrim's premier institution for magical education since the First Era.</p>

<section class="intro">
    <h2>Enroll in the magical arts</h2>
    <p>Choose from eight schools of magic, learn from master wizards, and shape your destiny.</p>
    <a href="/Student/Enroll" class="button">Begin Enrollment</a>
</section>

<hr />

