<p>Destruction Icon: @Html.MagicSchoolIcon(Department.Destruction)</p>
<p>Enchanting Icon: @Html.MagicSchoolIcon(Department.Enchanting)</p>
<p>Illusion Icon: @Html.MagicSchoolIcon(Department.Illusion)</p>
<p>Management Icon: @Html.MagicSchoolIcon(Department.Management)</p>
<p>Mysticism Icon: @Html.MagicSchoolIcon(Department.Mysticism)</p>
<p>Restoration Icon: @Html.MagicSchoolIcon(Department.Restoration)</p>

