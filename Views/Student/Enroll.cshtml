@{
    ViewData["Title"] = "Enroll as a Student";
}

<h1>Enroll at Winterhold College</h1>

<form method="post" action="/Student/Enroll">
    @Html.AntiForgeryToken()

    <div class="form-group">
        <label>Full Name</label>
        <input name="Name" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input name="Email" type="email" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Birth Date</label>
        <input name="BirthDate" type="date" class="form-control" required />
    </div>

    <div class="form-group">
        <label>Major</label>
        <select name="Major" class="form-control" required>
            <option value="">-- Select Major --</option>
            <option value="0">Alteration</option>
            <option value="1">Conjuration</option>
            <option value="2">Destruction</option>
            <option value="3">Illusion</option>
            <option value="4">Restoration</option>
            <option value="5">Mysticism</option>
            <option value="6">Enchanting</option>
            <option value="7">Management</option>
        </select>
    </div>

    <button type="submit" class="btn-submit">Submit Enrollment</button>
</form>